# Yandex OAuth (required for admin login)
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
ADMIN_EMAIL=your_admin_email@example.com

# Public host for OAuth callbacks
PUBLIC_HOST=https://your-domain.example.com

# Session security (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-random-secret

# LiteLLM / AI Models (optional, for AI chat)
LLM_MODEL=gemini-flash-lite
CONFIG_YAML_PATH=/path/to/config.yaml
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
LITELLM_BASE_URL=

# Optional web search
TAVILY_API_KEY=
